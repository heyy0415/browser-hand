## 4. React 前端规范（apps/web）

### 4.1 组件设计原则
- **受控优先**：状态由父组件管理，子组件通过 props 接收
- **组合优于继承**：使用组合模式构建复杂组件
- **Hooks 抽象**：业务逻辑抽离到自定义 Hooks

### 4.2 组件文件结构
```typescript
// components/ChatPanel/
├── ChatPanel.tsx        # 组件主文件
├── ChatPanel.types.ts   # 类型定义（可选，复杂组件使用）
├── ChatPanel.hooks.ts   # 组件专属 hooks（可选）
├── ChatPanel.styles.ts  # 样式（如使用 CSS-in-JS）
└── index.ts             # 统一导出
```

### 4.3 组件实现模板
```typescript

/**
 * 聊天组件 - 用于展示对话消息和接收用户输入
 */
export const Chat = forwardRef<ChatRef, ChatProps>(({
  messages,
  onSend,
  loading = false,
  placeholder = '输入消息...',
  className,
  ...rest
}, ref) => {
  // 1. Hooks
  const [inputValue, setInputValue] = useState('');
  
  // 2. 事件处理
  const handleSend = useCallback(() => {
    if (!inputValue.trim()) return;
    onSend(inputValue);
    setInputValue('');
  }, [inputValue, onSend]);

  // 3. 渲染
  return (
    <div className={`chat-container ${className}`} {...rest}>
      {/* 组件内容 */}
    </div>
  );
});

Chat.displayName = 'Chat';
```

### 4.4 自定义 Hooks 规范
```typescript
// apps/web/src/hooks/useTask.ts
import { useState, useCallback, useRef, useEffect } from 'react';
import type { TaskState, TaskEvent } from '@browser-hand/engine';

interface UseTaskOptions {
  onComplete?: (result: TaskResult) => void;
  onError?: (error: Error) => void;
}

interface UseTaskReturn {
  state: TaskState;
  start: (config: TaskConfig) => Promise<void>;
  cancel: () => void;
  reset: () => void;
}

/**
 * 任务管理 Hook - 处理 SSE 流式任务执行
 */
export function useTask(options?: UseTaskOptions): UseTaskReturn {
  const [state, setState] = useState<TaskState>('idle');
  const abortControllerRef = useRef<AbortController | null>(null);

  const start = useCallback(async (config: TaskConfig) => {
    // 实现逻辑
  }, []);

  const cancel = useCallback(() => {
    abortControllerRef.current?.abort();
  }, []);

  return { state, start, cancel, reset };
}
```

