## 7. 测试规范

### 7.1 测试文件位置
```
src/
├── components/
│   └── Button.tsx
└── __tests__/
    └── Button.test.tsx
```

### 7.2 测试模板
```typescript
// __tests__/engine/scanner.test.ts
import { describe, it, expect, beforeEach } from 'vitest';
import { ScannerLayer } from '../../packages/engine/src/layers/scanner';

describe('ScannerLayer', () => {
  let scanner: ScannerLayer;

  beforeEach(() => {
    scanner = new ScannerLayer({ /* config */ });
  });

  it('should scan page elements correctly', async () => {
    const input = { html: '<button>Click</button>' };
    const result = await scanner.process(input);
    
    expect(result.elements).toHaveLength(1);
    expect(result.elements[0].tag).toBe('button');
  });

  it('should validate input before processing', () => {
    expect(scanner.validate({ html: '' })).toBe(false);
  });
});
```

