### 3.3 Pipeline 流水线规范
```typescript
// packages/engine/src/pipeline.ts
export class Pipeline {
  private layers: Layer[];
  private eventEmitter: EventEmitter;

  /**
   * 注册处理层
   */
  register(layer: Layer): this

  /**
   * 执行流水线，返回 SSE 事件流
   */
  async execute(input: PipelineInput): AsyncGenerator<PipelineEvent>
}
