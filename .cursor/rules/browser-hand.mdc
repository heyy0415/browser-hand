## 5. 后端 API 规范（apps/server）

### 5.1 Hono 路由组织
```typescript
// apps/server/src/index.ts
import { Hono } from 'hono';
import { taskRouter } from './routes/task';
import { cors } from 'hono/cors';

const app = new Hono();

// 中间件
app.use('*', cors());

// 路由注册
app.route('/api/task', taskRouter);

export default app;
```

### 5.2 SSE 端点实现
```typescript
// apps/server/src/routes/task.ts
import { Hono } from 'hono';
import { stream } from 'hono/streaming';
import { Pipeline } from '@browser-hand/engine';

export const taskRouter = new Hono();

taskRouter.post('/execute', async (c) => {
  const body = await c.req.json();
  
  return stream(c, async (stream) => {
    const pipeline = new Pipeline();
    
    for await (const event of pipeline.execute(body)) {
      await stream.write(`data: ${JSON.stringify(event)}\n\n`);
    }
    
    await stream.close();
  });
});
```

### 5.3 错误处理
```typescript
// apps/server/src/middleware/error.ts
import type { ErrorHandler } from 'hono';

export const errorHandler: ErrorHandler = (err, c) => {
  console.error(`[Error] ${err.message}`, err.stack);
  
  return c.json({
    success: false,
    error: {
      code: err.cause || 'INTERNAL_ERROR',
      message: err.message,
    },
  }, 500);
};
```

