{
  "name": "browser-hand",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages",
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently --names \"server,web\" --prefix-colors \"cyan,magenta\" \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run build:web",
    "build:web": "bun run --cwd apps/web build",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "hono": "^4.12.9",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "1.3.11",
    "concurrently": "^9.1.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
